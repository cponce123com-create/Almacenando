# ────────────────────────────────────────────────────────────
#  Almacén Químico — Variables de entorno requeridas
#  Copia este archivo a .env y completa los valores reales
#  antes de correr el proyecto localmente.
#  En Render/producción, configura estas variables en el dashboard.
# ────────────────────────────────────────────────────────────

# ── Entorno y servidor ───────────────────────────────────────
# "production" en Render, "development" localmente, "test" en CI.
NODE_ENV=development

# Puerto donde escucha el servidor API.
# Render asigna este valor automáticamente; localmente usa 3000.
PORT=3000

# Número de proxies delante del servidor (Render usa 1).
# Solo cambiar si usas otro hosting con múltiples proxies.
TRUST_PROXY=1

# Ruta al build del frontend. Por defecto:
#   artifacts/legado/dist/public
# Solo cambiar si tu estructura de deploy es distinta.
# FRONTEND_DIST_PATH=

# Nivel de logs: "debug", "info", "warn", "error". Default: "info".
# LOG_LEVEL=info


# ── Autenticación ────────────────────────────────────────────
# Clave secreta para firmar los JWT de sesión.
# DEBE ser una cadena larga y aleatoria (mínimo 48 caracteres).
# Genera una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-hex-string

# Clave para el endpoint de configuración inicial del administrador.
# Usada en POST /api/auth/setup para crear el primer usuario admin.
ADMIN_SETUP_KEY=replace-with-a-secret-setup-key


# ── Admin bootstrap (solo se usa si la DB está vacía) ────────
# Al arrancar el servidor con la base vacía, se crea un admin con
# estos datos. Después del primer deploy puedes borrarlos.
# IMPORTANTE: ADMIN_PASSWORD DEBE cumplir la política:
#   - mínimo 8 caracteres
#   - al menos 1 mayúscula
#   - al menos 1 número
ADMIN_EMAIL=admin@tudominio.com
ADMIN_NAME=Administrador
ADMIN_PASSWORD=CambiaEstaClave123


# ── Base de datos (PostgreSQL) ───────────────────────────────
# En Render se obtiene desde el dashboard del servicio de base de datos.
# Ejemplo local: postgresql://user:password@localhost:5432/almacen_quimico
DATABASE_URL=postgresql://user:password@localhost:5432/almacen_quimico


# ── URL pública de la app ────────────────────────────────────
# URL del servicio de API desplegado. Se usa para CORS y para
# construir los enlaces que se envían por email.
# Ejemplo: https://almacen-quimico-api.onrender.com
APP_URL=https://your-api-service.onrender.com


# ── Cloudinary — fotos de inventario ─────────────────────────
# Crea una cuenta gratuita en https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret


# ── Email (Resend) — transaccional general ───────────────────
# Crea una cuenta en https://resend.com (3000 emails/mes gratis).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@tudominio.com


# ── Email (SMTP Gmail) — notificaciones internas ─────────────
# Solo si usas el flujo "Carlos Ponce" para enviar stocks por SMTP.
# Genera un "App Password" en https://myaccount.google.com/apppasswords
SMTP_USER=tu-correo@gmail.com
SMTP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx


# ── Google Drive — almacenamiento de MSDS y documentos ───────
# Cuenta de servicio con permiso de escritura en la carpeta destino.
# Pega el JSON completo de la service account (escapando saltos de línea).
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=


# ── OpenAI (extracción automática de MSDS) ───────────────────
# Usa el proxy de Replit AI Integrations o tu key directa de OpenAI.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Flags de mantenimiento (NO dejar en true permanentemente) ─
# Ejecuta el seed de datos de demo en el próximo arranque.
# Úsalo una sola vez en la primera instalación; luego elimínalo.
# RUN_SEED=true

# Elimina registros con códigos PROD-* al arrancar.
# Úsalo una sola vez para limpiar datos demo; luego elimínalo.
# CLEANUP_DEMO_DATA=true
