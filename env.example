# ────────────────────────────────────────────────────────────
#  Almacén Químico — Variables de entorno requeridas
#  Copia este archivo a .env y completa los valores reales
#  antes de correr el proyecto localmente.
#  En Render/producción, configura estas variables en el dashboard.
# ────────────────────────────────────────────────────────────

# ── Autenticación ────────────────────────────────────────────
# Clave secreta para firmar los JWT de sesión.
# DEBE ser una cadena larga y aleatoria (mínimo 48 caracteres).
# Genera una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-hex-string

# Clave para el endpoint de configuración inicial del administrador.
# Usada en POST /api/auth/setup para crear el primer usuario admin.
ADMIN_SETUP_KEY=replace-with-a-secret-setup-key

# ── Base de datos (PostgreSQL) ───────────────────────────────
# En Render se obtiene desde el dashboard del servicio de base de datos.
# Ejemplo local: postgresql://user:password@localhost:5432/almacen_quimico
DATABASE_URL=postgresql://user:password@localhost:5432/almacen_quimico

# ── URL pública de la app ────────────────────────────────────
# URL del servicio de API desplegado.
# Ejemplo: https://almacen-quimico-api.onrender.com
APP_URL=https://your-api-service.onrender.com

# ── Cloudinary — fotos de inventario ────────────────────────
# Crea una cuenta gratuita en https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Email (Resend) ───────────────────────────────────────────
# Crea una cuenta en https://resend.com (3 000 emails/mes gratis).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@tudominio.com
