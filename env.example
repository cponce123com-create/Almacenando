# ────────────────────────────────────────────────────────────
#  Almacenando — Variables de entorno requeridas
#  Copia este archivo a .env y completa los valores reales
#  antes de correr el proyecto localmente.
#  En Render, configura estas variables en el dashboard.
# ────────────────────────────────────────────────────────────

# Clave secreta para firmar los JWT de sesión.
# DEBE ser una cadena larga y aleatoria (mínimo 48 caracteres).
# Genera una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-hex-string

# ── Email (Resend — recomendado) ────────────────────────────
# Crea una cuenta gratuita en https://resend.com (3.000 emails/mes).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudinary — almacenamiento de archivos/documentos ──────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── URL pública de la app ────────────────────────────────────
# En Render, es la URL del servicio desplegado.
# Ejemplo: https://almacenando-api.onrender.com
APP_URL=https://your-service.onrender.com

# ── Base de datos (Postgres) ─────────────────────────────────
# En Render se configura desde el dashboard (Internal Database URL).
DATABASE_URL=postgresql://user:password@localhost:5432/almacenando
