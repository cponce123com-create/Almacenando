# ────────────────────────────────────────────────────────────
#  Legado — Required Environment Variables
#  Copy to .env and fill in real values before running locally.
#  In Replit, set these as Secrets (Environment Variables tab).
# ────────────────────────────────────────────────────────────

# JWT signing secret — MUST be a long, random string (≥ 48 chars).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-hex-string

# One-time key used to create the first admin account via POST /api/admin/setup.
# Remove or leave unset in production once admin is created.
ADMIN_SETUP_KEY=replace-with-a-strong-setup-key

# ── Email (Resend — recomendado) ────────────────────────────
# Crea una cuenta gratuita en https://resend.com (3.000 emails/mes).
# Verifica tu dominio o usa el sandbox de Resend para pruebas.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dirección From que aparece en los correos (debe estar verificada en Resend).
RESEND_FROM_EMAIL=Legado <noreply@tu-dominio.com>

# ── Cloudinary — almacenamiento de medios ───────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── RENIEC — verificación de DNI peruano ────────────────────
# Obtén tu token en https://apiperu.dev o https://decolecta.com
RENIEC_API_TOKEN=your-reniec-api-token

# ── IA — Anthropic Claude (generador de testamento) ─────────
# Opción A: API key propia de Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opción B: Integración de Replit (se configura automáticamente en Replit)
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://...
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=...

# ── YouTube — música del sepelio ────────────────────────────
# Obtén tu clave en https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── URL pública de la app ────────────────────────────────────
# Se usa en los enlaces de email de invitación y confirmación.
APP_URL=https://your-replit-subdomain.replit.app

# ── Base de datos (Postgres) ─────────────────────────────────
# En Replit se configura automáticamente. Para desarrollo local:
DATABASE_URL=postgresql://user:password@localhost:5432/legado
