DATABASE_URL=postgresql://user:password@localhost:5432/legado

# Email provider — se usa RESEND si RESEND_API_KEY está definida;
# de lo contrario se cae en Gmail (nodemailer).
# Recomendado para producción: Resend (https://resend.com) — plan gratuito 3000 emails/mes
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Gmail fallback (solo para desarrollo / pruebas locales)
# Requiere App Password de Google: https://myaccount.google.com/apppasswords
EMAIL_USER=tu@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# Cloudinary — almacenamiento de archivos cifrados
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# IA — Integración Replit Anthropic (generador de testamento)
# Se configura automáticamente si usas la integración de Replit AI.
# Para desarrollo local con tu propia clave:
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# YouTube Data API v3 — para el buscador de música funeraria
# Crear en: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL base de la app (usada en los emails de liberación)
APP_URL=https://legadoapp.replit.app

# Credenciales del administrador (se validan contra estas variables)
ADMIN_EMAIL=admin@legadoapp.com
ADMIN_PASSWORD=CambiarEsto_ConContraseñaSegura
